<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- DayNight so the pre-Compose window background follows the system scheme
         (values-night overrides @color/bg); Compose then draws the real UI. -->
    <style name="Theme.Kabanchiki" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
    </style>
</resources>
